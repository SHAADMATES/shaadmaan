datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  password      String
  role          String
  plainPassword String   @default("")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  auditLogs    AuditLog[]
  programs     Program[]
  student      Student?
  wingChairman WingChairman?
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  username  String   @default("system")
  action    String
  details   String   @default("")
  timestamp DateTime @default(now())
}

model Certificate {
  id            String   @id @default(uuid())
  certificateId String   @unique
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  programId     String
  program       Program  @relation(fields: [programId], references: [id])
  position      String
  grade         String
  approved      Boolean  @default(false)
  issueDate     DateTime @default(now())
}

model Finance {
  id          String   @id @default(uuid())
  type        String
  category    String
  amount      Float
  description String   @default("")
  date        DateTime @default(now())
  programId   String?
  program     Program? @relation(fields: [programId], references: [id])
  createdAt   DateTime @default(now())
}

model FormField {
  id        String   @id @default(uuid())
  formName  String
  label     String
  name      String
  type      String
  required  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Group {
  id        String   @id @default(uuid())
  name      String
  leaderId  String
  leader    Student  @relation("GroupLeader", fields: [leaderId], references: [id])
  createdAt DateTime @default(now())

  members       Student[]      @relation("GroupMembers")
  registrations Registration[]
  winners       Winner[]
}

model Library {
  id          String   @id @default(uuid())
  title       String
  author      String
  category    String
  pdfUrl      String
  downloads   Int      @default(0)
  description String   @default("")
  createdAt   DateTime @default(now())
}

model Notification {
  id            String   @id @default(uuid())
  title         String
  message       String
  type          String
  recipientRole String   @default("all")
  createdAt     DateTime @default(now())
}

model Program {
  id              String   @id @default(uuid())
  title           String
  type            String
  wing            String
  date            DateTime
  time            String
  venue           String
  description     String   @default("")
  maxParticipants Int      @default(0)
  rules           String   @default("[]") // Stored as JSON string
  approved        Boolean  @default(false)
  status          String   @default("Upcoming")
  createdById     String?
  createdBy       User?    @relation(fields: [createdById], references: [id])
  createdAt       DateTime @default(now())

  certificates  Certificate[]
  finances      Finance[]
  registrations Registration[]
  results       Result[]
  schedules     Schedule[]
}

model Publication {
  id        String   @id @default(uuid())
  title     String
  content   String
  language  String
  category  String
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  status    String   @default("Pending")
  fileUrl   String   @default("")
  createdAt DateTime @default(now())
}

model Registration {
  id               String   @id @default(uuid())
  programId        String
  program          Program  @relation(fields: [programId], references: [id])
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id])
  type             String
  groupId          String?
  group            Group?   @relation(fields: [groupId], references: [id])
  registrationDate DateTime @default(now())
}

model ReportLog {
  id          String   @id @default(uuid())
  title       String
  type        String
  generatedAt DateTime @default(now())
}

model Result {
  id          String   @id @default(uuid())
  programId   String
  program     Program  @relation(fields: [programId], references: [id])
  type        String
  publishedAt DateTime @default(now())

  winners Winner[]
}

model Winner {
  id        String   @id @default(uuid())
  position  String
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id])
  grade     String
  marks     Float
  points    Float
  remarks   String   @default("")
  resultId  String
  result    Result   @relation(fields: [resultId], references: [id], onDelete: Cascade)
}

model Schedule {
  id          String   @id @default(uuid())
  programId   String
  program     Program  @relation(fields: [programId], references: [id])
  date        DateTime
  time        String
  venue       String
  description String   @default("")
  createdAt   DateTime @default(now())
}

model Student {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  name            String
  studentId       String   @unique
  admissionNumber String   @unique
  className       String   @default("Class XII") @map("class")
  wing            String   @default("")
  photo           String   @default("")
  dob             DateTime @default(now())
  address         String   @default("")
  phone           String   @default("")
  email           String   @default("")
  createdAt       DateTime @default(now())

  certificates  Certificate[]
  ledGroups     Group[]        @relation("GroupLeader")
  memberGroups  Group[]        @relation("GroupMembers")
  publications  Publication[]
  registrations Registration[]
  wonResults    Winner[]
}

model SystemSetting {
  id           String @id @default(uuid())
  orgName      String @default("Shaad-Mates Website")
  orgLogo      String @default("🎓")
  orgEmail     String @default("admin@shaadmates.com")
  signatureUrl String @default("")
}

model Wing {
  id          String        @id @default(uuid())
  name        String        @unique
  logo        String        @default("")
  description String        @default("")
  chairmanId  String?       @unique
  chairman    WingChairman? @relation(fields: [chairmanId], references: [id])
  createdAt   DateTime      @default(now())
}

model WingChairman {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  name          String
  wing          String   @unique
  phone         String   @default("")
  email         String   @default("")
  assistantName String   @default("")
  photo         String   @default("")
  createdAt     DateTime @default(now())

  wings Wing[]
}
